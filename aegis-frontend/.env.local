# AEGIS Frontend Environment Configuration
# Backend API base URL — used by server-side Next.js routes
AEGIS_API_URL=http://127.0.0.1:8000

# Public URL — available in browser bundles (must be prefixed NEXT_PUBLIC_)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# WebSocket URL
NEXT_PUBLIC_WS_URL=ws://127.0.0.1:8000
